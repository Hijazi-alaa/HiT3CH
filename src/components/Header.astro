---
import { getTranslation } from '../utils/translations';
import type { Language } from '../utils/constants';
import LanguageToggle from './LanguageToggle.astro';

export interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

// Get current path without language prefix
const currentPath = Astro.url.pathname.replace(/^\/(en|sv)/, '') || '/';
---

<header class="sticky top-0 z-40 w-full bg-white/95 backdrop-blur-sm border-b border-secondary-200">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href={`/${lang}`} class="flex items-center space-x-2 font-bold text-xl text-primary-600 hover:text-primary-700 transition-colors">
          <svg class="icon-lg" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="6" fill="currentColor"/>
            <path d="M8 12h16M8 16h16M8 20h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span>HiT3CH</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        <a href={`/${lang}`} class="nav-link" data-current={currentPath === '/' ? 'true' : 'false'}>
          {t.nav.home}
        </a>
        <a href={`/${lang}/services`} class="nav-link" data-current={currentPath === '/services' ? 'true' : 'false'}>
          {t.nav.services}
        </a>
        <a href={`/${lang}/use-cases`} class="nav-link" data-current={currentPath === '/use-cases' ? 'true' : 'false'}>
          {t.nav.useCases}
        </a>
        <a href={`/${lang}/about`} class="nav-link" data-current={currentPath === '/about' ? 'true' : 'false'}>
          {t.nav.about}
        </a>
        <a href={`/${lang}/contact`} class="nav-link" data-current={currentPath === '/contact' ? 'true' : 'false'}>
          {t.nav.contact}
        </a>
      </div>

      <!-- Right side: Language toggle and CTA -->
      <div class="hidden md:flex items-center space-x-4">
        <LanguageToggle lang={lang} currentPath={currentPath} />
        <a
          href={`/${lang}/contact`}
          class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition-colors font-medium focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          {t.nav.bookDemo}
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center space-x-2">
        <LanguageToggle lang={lang} currentPath={currentPath} />
        <button 
          id="mobile-menu-button"
          type="button" 
          class="p-2 rounded-md text-secondary-600 hover:text-secondary-900 hover:bg-secondary-100 focus:outline-none focus:ring-2 focus:ring-primary-500"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <svg class="icon-md" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden">
      <div class="px-2 pt-2 pb-3 space-y-1 bg-white border-t border-secondary-200">
        <a href={`/${lang}`} class="mobile-nav-link" data-current={currentPath === '/' ? 'true' : 'false'}>
          {t.nav.home}
        </a>
        <a href={`/${lang}/services`} class="mobile-nav-link" data-current={currentPath === '/services' ? 'true' : 'false'}>
          {t.nav.services}
        </a>
        <a href={`/${lang}/use-cases`} class="mobile-nav-link" data-current={currentPath === '/use-cases' ? 'true' : 'false'}>
          {t.nav.useCases}
        </a>
        <a href={`/${lang}/about`} class="mobile-nav-link" data-current={currentPath === '/about' ? 'true' : 'false'}>
          {t.nav.about}
        </a>
        <a href={`/${lang}/contact`} class="mobile-nav-link" data-current={currentPath === '/contact' ? 'true' : 'false'}>
          {t.nav.contact}
        </a>
        <div class="pt-2">
          <a 
            href={`/${lang}/contact`}
            class="block w-full text-center bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition-colors font-medium"
          >
            {t.nav.bookDemo}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuButton?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden') === false;
    
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
    } else {
      mobileMenu?.classList.remove('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'true');
    }
  });

  // Close mobile menu when clicking outside
  document.addEventListener('click', (e) => {
    if (!mobileMenuButton?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
      mobileMenu?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .nav-link {
    @apply text-secondary-700 hover:text-primary-600 transition-colors font-medium;
  }
  
  .nav-link[data-current="true"] {
    @apply text-primary-600;
  }
  
  .mobile-nav-link {
    @apply block px-3 py-2 text-secondary-700 hover:text-primary-600 hover:bg-secondary-50 transition-colors font-medium rounded-md;
  }
  
  .mobile-nav-link[data-current="true"] {
    @apply text-primary-600 bg-primary-50;
  }
</style>