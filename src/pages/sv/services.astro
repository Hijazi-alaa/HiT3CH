---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslation } from '../../utils/translations';

const t = getTranslation('sv');
---

<BaseLayout
  title="AI-tjänster - Röst- & Chattagenter | HiT3CH"
  description="Välj från vår AI-receptionist för småföretag (från 20 000 SEK) eller anpassad AI för företag (från 80 000 SEK). Alla lösningar inkluderar röst- & chattfunktioner, automation och GDPR-efterlevnad."
  lang="sv"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-50 to-secondary-50 py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-secondary-900 mb-6">
          {t.services.title}
        </h1>
        <p class="text-xl text-secondary-600 mb-8 max-w-3xl mx-auto">
          {t.services.subtitle}
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-white" data-pagefind-body>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Track 1: AI-receptionist -->
        <div class="bg-white border-2 border-secondary-200 rounded-2xl p-8 hover:shadow-xl transition-shadow">
          <div class="mb-6">
            <div class="w-16 h-16 bg-primary-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-secondary-900 mb-2">
              {t.services.track1.title}
            </h2>
            <div class="text-3xl font-bold text-primary-600 mb-4">
              {t.services.track1.price}
            </div>
            <p class="text-secondary-600 mb-6">
              {t.services.track1.desc}
            </p>
          </div>

          <div class="space-y-3 mb-8">
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-secondary-700">Grundläggande tidbokning</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-secondary-700">FAQ-hantering</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-secondary-700">Leadinsamling</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-secondary-700">Öppettidstäckning</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-secondary-700">2 veckors implementation</span>
            </div>
          </div>

          <a 
            href="/sv/contact"
            class="block w-full bg-primary-600 text-white text-center py-3 rounded-lg font-semibold hover:bg-primary-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          >
            Kom Igång
          </a>
        </div>

        <!-- Track 2: Anpassad AI -->
        <div class="bg-gradient-to-br from-primary-600 to-primary-700 text-white rounded-2xl p-8 hover:shadow-xl transition-shadow relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-yellow-400 text-yellow-900 px-3 py-1 text-sm font-semibold">
            Populärast
          </div>
          
          <div class="mb-6">
            <div class="w-16 h-16 bg-white/20 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2">
              {t.services.track2.title}
            </h2>
            <div class="text-3xl font-bold mb-4">
              {t.services.track2.price}
            </div>
            <p class="text-primary-100 mb-6">
              {t.services.track2.desc}
            </p>
          </div>

          <div class="space-y-3 mb-8">
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-primary-100">Avancerad arbetsflödesautomatisering</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-primary-100">Anpassade integrationer</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-primary-100">Multi-avdelningsroutning</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-primary-100">Avancerad analys</span>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-primary-100">Prioriterad support</span>
            </div>
          </div>

          <a 
            href="/sv/contact"
            class="block w-full bg-white text-primary-600 text-center py-3 rounded-lg font-semibold hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-primary-600"
          >
            Kom Igång
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Shared Features -->
  <section class="py-20 bg-secondary-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-secondary-900 text-center mb-12">
          {t.services.sharedFeatures.title}
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-secondary-900 mb-2">
              {t.services.sharedFeatures.voiceChat}
            </h3>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-secondary-900 mb-2">
              {t.services.sharedFeatures.automation}
            </h3>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-secondary-900 mb-2">
              {t.services.sharedFeatures.bilingual}
            </h3>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-secondary-900 mb-2">
              {t.services.sharedFeatures.gdpr}
            </h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-secondary-900 text-center mb-12">
          {t.services.faq.title}
        </h2>
        
        <div class="space-y-8">
          <div class="border border-secondary-200 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-secondary-900 mb-3">
              {t.services.faq.q1}
            </h3>
            <p class="text-secondary-600">
              {t.services.faq.a1}
            </p>
          </div>

          <div class="border border-secondary-200 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-secondary-900 mb-3">
              {t.services.faq.q2}
            </h3>
            <p class="text-secondary-600">
              {t.services.faq.a2}
            </p>
          </div>

          <div class="border border-secondary-200 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-secondary-900 mb-3">
              {t.services.faq.q3}
            </h3>
            <p class="text-secondary-600">
              {t.services.faq.a3}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary-600 text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Redo att Komma Igång?
      </h2>
      <p class="text-xl mb-8 text-primary-100 max-w-2xl mx-auto">
        Boka en gratis konsultation för att diskutera vilken AI-lösning som passar ditt företag.
      </p>
      <a 
        href="/sv/contact"
        class="bg-white text-primary-600 px-8 py-4 rounded-lg font-semibold hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-primary-600"
      >
        Boka Gratis Konsultation
      </a>
    </div>
  </section>
</BaseLayout>