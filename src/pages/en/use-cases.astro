---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI Use Cases & Demos - Real Business Applications | HiT3CH"
  description="Explore real-world AI applications: Clinic Receptionist AI, eCommerce Chat Agent, and Energy Company Support AI. See demos and expected business impact."
  lang="en"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-50 to-secondary-50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-secondary-900 mb-6">
          AI Use Cases & Demos
        </h1>
        <p class="text-xl text-secondary-600 mb-8 max-w-3xl mx-auto">
          Discover how AI agents are transforming customer service across different industries. Explore realistic scenarios and expected business outcomes.
        </p>
      </div>
    </div>
  </section>

  <!-- Use Cases Grid -->
  <section class="py-20 bg-white" data-pagefind-body>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Use Case 1: Clinic Receptionist AI -->
      <div class="max-w-6xl mx-auto mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 mb-4">
              Healthcare
            </div>
            <h2 class="text-3xl font-bold text-secondary-900 mb-4">
              Clinic Receptionist AI
            </h2>
            
            <div class="space-y-6">
              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Problem</h3>
                <p class="text-secondary-600">
                  Long wait times, missed calls during peak hours, staff burnout, and patients frustrated with busy phone lines. High operational costs for reception staff.
                </p>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Solution</h3>
                <p class="text-secondary-600">
                  AI agent handles appointment scheduling, prescription renewal requests, basic medical information, and routes complex queries to appropriate staff members.
                </p>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Expected Impact</h3>
                <div class="grid grid-cols-2 gap-4">
                  <div class="bg-green-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-green-600">75%</div>
                    <div class="text-sm text-green-700">Reduction in call wait times</div>
                  </div>
                  <div class="bg-green-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-green-600">60%</div>
                    <div class="text-sm text-green-700">Decrease in missed calls</div>
                  </div>
                  <div class="bg-green-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-green-600">40%</div>
                    <div class="text-sm text-green-700">Staff time saved</div>
                  </div>
                  <div class="bg-green-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-green-600">90%</div>
                    <div class="text-sm text-green-700">Patient satisfaction improvement</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-secondary-100 rounded-xl p-8 h-96 flex items-center justify-center">
            <div class="text-center text-secondary-600">
              <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-9 11v5a2 2 0 002 2h6a2 2 0 002-2v-5M7 4h10l1 12H6L7 4z"></path>
              </svg>
              <h3 class="text-lg font-semibold mb-2">Interactive Demo</h3>
              <p class="text-sm">Demo placeholder - voice/chat interface simulation would be embedded here</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Use Case 2: eCommerce Chat Agent -->
      <div class="max-w-6xl mx-auto mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1">
            <div class="bg-secondary-100 rounded-xl p-8 h-96 flex items-center justify-center">
              <div class="text-center text-secondary-600">
                <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                </svg>
                <h3 class="text-lg font-semibold mb-2">Shopping Assistant Demo</h3>
                <p class="text-sm">Interactive chat widget simulation for product recommendations and support</p>
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2">
            <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-800 mb-4">
              eCommerce
            </div>
            <h2 class="text-3xl font-bold text-secondary-900 mb-4">
              eCommerce Chat Agent
            </h2>
            
            <div class="space-y-6">
              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Problem</h3>
                <p class="text-secondary-600">
                  Limited support hours, high cart abandonment rate, repetitive customer queries, and need for multilingual support across European markets.
                </p>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Solution</h3>
                <p class="text-secondary-600">
                  AI chat agent provides product recommendations, order status updates, size guidance, return processing, and seamlessly escalates to human agents when needed.
                </p>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Expected Impact</h3>
                <div class="grid grid-cols-2 gap-4">
                  <div class="bg-blue-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-blue-600">25%</div>
                    <div class="text-sm text-blue-700">Increase in conversion rate</div>
                  </div>
                  <div class="bg-blue-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-blue-600">70%</div>
                    <div class="text-sm text-blue-700">Reduction in support tickets</div>
                  </div>
                  <div class="bg-blue-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-blue-600">35%</div>
                    <div class="text-sm text-blue-700">Decrease in cart abandonment</div>
                  </div>
                  <div class="bg-blue-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-blue-600">24/7</div>
                    <div class="text-sm text-blue-700">Customer support availability</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Use Case 3: Energy Company Support AI -->
      <div class="max-w-6xl mx-auto mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 mb-4">
              Energy & Utilities
            </div>
            <h2 class="text-3xl font-bold text-secondary-900 mb-4">
              Energy Company Support AI
            </h2>
            
            <div class="space-y-6">
              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Problem</h3>
                <p class="text-secondary-600">
                  Seasonal call spikes during outages, complex billing inquiries, regulatory compliance requirements, and need for emergency response coordination.
                </p>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Solution</h3>
                <p class="text-secondary-600">
                  AI agent handles outage reporting, billing explanations, energy efficiency advice, service requests, and provides real-time updates during emergencies.
                </p>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-secondary-900 mb-2">Expected Impact</h3>
                <div class="grid grid-cols-2 gap-4">
                  <div class="bg-orange-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-orange-600">50%</div>
                    <div class="text-sm text-orange-700">Faster outage reporting</div>
                  </div>
                  <div class="bg-orange-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-orange-600">80%</div>
                    <div class="text-sm text-orange-700">Billing queries automated</div>
                  </div>
                  <div class="bg-orange-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-orange-600">60%</div>
                    <div class="text-sm text-orange-700">Reduction in call volume</div>
                  </div>
                  <div class="bg-orange-50 p-4 rounded-lg">
                    <div class="text-2xl font-bold text-orange-600">95%</div>
                    <div class="text-sm text-orange-700">Customer satisfaction during outages</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-secondary-100 rounded-xl p-8 h-96 flex items-center justify-center">
            <div class="text-center text-secondary-600">
              <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              <h3 class="text-lg font-semibold mb-2">Service Dashboard Demo</h3>
              <p class="text-sm">Outage reporting and billing support interface simulation</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary-600 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Ready to See Your Use Case in Action?
      </h2>
      <p class="text-xl mb-8 text-primary-100 max-w-2xl mx-auto">
        <span data-en="See a working example or talk to us about your own project." data-sv="Se ett fungerande exempel eller prata med oss om ditt eget projekt.">See a working example or talk to us about your own project.</span>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/en/demo"
          class="bg-white text-primary-600 px-8 py-4 rounded-lg font-semibold hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-primary-600"
        >
          <span data-en="See a Live Prototype" data-sv="Se en liveprototyp">See a Live Prototype</span>
        </a>
        <a
          href="/en/contact"
          class="border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white hover:text-primary-600 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-primary-600"
        >
          <span data-en="Book a Free Consultation" data-sv="Boka en gratis konsultation">Book a Free Consultation</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>