---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { SITE_CONFIG } from '../../utils/constants';
---

<BaseLayout
  title="Contact HiT3CH - Free AI Consultation"
  description="Get started with AI-powered voice and chat agents. Book a free consultation or contact our team to discuss your business needs."
  lang="en"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-50 to-secondary-50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-secondary-900 mb-6">
          <span data-en="Contact Us" data-sv="Kontakta oss">Contact Us</span>
        </h1>
        <p class="text-xl text-secondary-600 mb-8 max-w-3xl mx-auto">
          <span data-en="Ready to transform your customer service with AI? Get in touch with our team or book a free consultation to see how we can help your business." data-sv="Redo att transformera din kundservice med AI? Kontakta vårt team eller boka en gratis konsultation för att se hur vi kan hjälpa ditt företag.">Ready to transform your customer service with AI? Get in touch with our team or book a free consultation to see how we can help your business.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-secondary-900 mb-6">Send us a message</h2>
          <ContactForm lang="en" />
        </div>

        <!-- Booking Calendar & Info -->
        <div class="space-y-8">
          <!-- Book Consultation Section -->
          <div id="book-demo">
            <h2 class="text-2xl font-bold text-secondary-900 mb-6">
              <span data-en="Book a Free Consultation" data-sv="Boka en gratis konsultation">Book a Free Consultation</span>
            </h2>
            <div class="bg-secondary-50 rounded-lg p-6">
              <p class="text-secondary-700 mb-4">
                <span data-en="Schedule a 30-minute call to discuss how our AI agents can benefit your business." data-sv="Boka ett 30-minuters samtal för att diskutera hur våra AI-agenter kan gynna ditt företag.">Schedule a 30-minute call to discuss how our AI agents can benefit your business.</span>
              </p>
              
              <!-- Calendly Embed Placeholder -->
              <div class="calendly-embed bg-white rounded-lg border border-secondary-200 h-96 flex items-center justify-center">
                <div class="text-center text-secondary-600">
                  <svg class="w-12 h-12 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <p class="font-medium">Calendly booking widget will appear here</p>
                  <p class="text-sm text-secondary-500">Update CALENDLY_URL in constants.ts</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Information -->
          <div class="bg-primary-600 text-white rounded-lg p-8">
            <h3 class="text-xl font-bold mb-6">Get in Touch</h3>
            
            <div class="space-y-4">
              <div class="flex items-start">
                <svg class="w-6 h-6 text-primary-200 mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <div>
                  <h4 class="font-semibold">Email</h4>
                  <p class="text-primary-100">hello@hitech.ai</p>
                </div>
              </div>

              <div class="flex items-start">
                <svg class="w-6 h-6 text-primary-200 mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <h4 class="font-semibold">Location</h4>
                  <p class="text-primary-100">Stockholm, Sweden</p>
                </div>
              </div>

              <div class="flex items-start">
                <svg class="w-6 h-6 text-primary-200 mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <h4 class="font-semibold">Response Time</h4>
                  <p class="text-primary-100">Within 24 hours</p>
                </div>
              </div>
            </div>

            <div class="mt-8 pt-6 border-t border-primary-500">
              <h4 class="font-semibold mb-4">Follow us</h4>
              <div class="flex space-x-4">
                <a href="https://www.linkedin.com/company/hitech-ai" class="text-primary-200 hover:text-white transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
                <a href="https://www.facebook.com/hitech.ai" class="text-primary-200 hover:text-white transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ CALENDLY_URL: SITE_CONFIG.CALENDLY_URL }}>
  // Load Calendly widget if URL is configured
  if (CALENDLY_URL && CALENDLY_URL !== 'https://calendly.com/your-username/demo') {
    // Create Calendly script
    const calendlyScript = document.createElement('script');
    calendlyScript.src = 'https://assets.calendly.com/assets/external/widget.js';
    calendlyScript.async = true;
    
    calendlyScript.onload = function() {
      // Initialize Calendly widget
      const calendlyContainer = document.querySelector('.calendly-embed');
      if (calendlyContainer && window.Calendly) {
        calendlyContainer.innerHTML = '';
        window.Calendly.initInlineWidget({
          url: CALENDLY_URL,
          parentElement: calendlyContainer,
          prefill: {},
          utm: {}
        });
      }
    };
    
    document.head.appendChild(calendlyScript);
  }
</script>