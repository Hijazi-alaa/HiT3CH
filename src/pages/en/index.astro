---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslation } from '../../utils/translations';

const t = getTranslation('en');
const tSv = getTranslation('sv');
---

<BaseLayout
  title="HiT3CH - AI Automations for Your Business"
  description="We design and integrate AI automations, including voice and chat agents for customer service. Book a free consultation or see a live prototype."
  lang="en"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-50 to-secondary-50 py-20 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-secondary-900 mb-6">
          <span data-en={t.home.headline} data-sv={tSv.home.headline}>{t.home.headline}</span>
        </h1>
        <p class="text-xl md:text-2xl text-secondary-600 mb-8 max-w-3xl mx-auto">
          <span data-en={t.home.subheadline} data-sv={tSv.home.subheadline}>{t.home.subheadline}</span>
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/en/contact"
            class="bg-primary-600 text-white px-8 py-4 rounded-lg font-semibold hover:bg-primary-700 transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          >
            <span data-en={t.home.cta1} data-sv={tSv.home.cta1}>{t.home.cta1}</span>
          </a>
          <a
            href="/en/demo"
            class="bg-white text-primary-600 border-2 border-primary-600 px-8 py-4 rounded-lg font-semibold hover:bg-primary-600 hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          >
            <span data-en={t.home.cta2} data-sv={tSv.home.cta2}>{t.home.cta2}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props Section -->
  <section class="py-20 bg-white" data-pagefind-body>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-secondary-900 mb-4">
          {t.home.valueProps.title}
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 rounded-xl border border-secondary-200 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-secondary-900 mb-4">
            {t.home.valueProps.saveTime.title}
          </h3>
          <p class="text-secondary-600">
            {t.home.valueProps.saveTime.desc}
          </p>
        </div>

        <div class="text-center p-8 rounded-xl border border-secondary-200 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-secondary-900 mb-4">
            {t.home.valueProps.boostExperience.title}
          </h3>
          <p class="text-secondary-600">
            {t.home.valueProps.boostExperience.desc}
          </p>
        </div>

        <div class="text-center p-8 rounded-xl border border-secondary-200 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-secondary-900 mb-4">
            {t.home.valueProps.seamlessIntegration.title}
          </h3>
          <p class="text-secondary-600">
            {t.home.valueProps.seamlessIntegration.desc}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries Section -->
  <section class="py-20 bg-secondary-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-secondary-900 mb-4">
          {t.home.industries.title}
        </h2>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
        <div class="bg-white p-6 rounded-xl text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="font-medium text-secondary-900">{t.home.industries.healthcare}</h3>
        </div>

        <div class="bg-white p-6 rounded-xl text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
          </div>
          <h3 class="font-medium text-secondary-900">{t.home.industries.retail}</h3>
        </div>

        <div class="bg-white p-6 rounded-xl text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-medium text-secondary-900">{t.home.industries.energy}</h3>
        </div>

        <div class="bg-white p-6 rounded-xl text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="font-medium text-secondary-900">{t.home.industries.publicServices}</h3>
        </div>

        <div class="bg-white p-6 rounded-xl text-center hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="font-medium text-secondary-900">{t.home.industries.ecommerce}</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary-600 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Ready to Transform Your Customer Service?
      </h2>
      <p class="text-xl mb-8 text-primary-100 max-w-2xl mx-auto">
        Join Swedish businesses already using AI to deliver exceptional customer experiences.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/en/demo"
          class="bg-white text-primary-600 px-8 py-4 rounded-lg font-semibold hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-primary-600"
        >
          <span data-en="See a Live Prototype" data-sv="Se en liveprototyp">See a Live Prototype</span>
        </a>
        <a
          href="/en/contact"
          class="border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white hover:text-primary-600 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-primary-600"
        >
          <span data-en="Book a Free Consultation" data-sv="Boka en gratis konsultation">Book a Free Consultation</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>